@using GalacticTitans.Core.Domain
@using GalacticTitans.Core.ServiceInterface
@using Microsoft.AspNetCore.Identity;
@inject SignInManager<GalacticTitans.Core.Domain.ApplicationUser> signInManager;
@inject UserManager<GalacticTitans.Core.Domain.ApplicationUser> userManager;
@inject IPlayerProfilesServices PlayerProfilesServices;

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GalacticTitans</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GalacticTitans.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/gameStyle.css" />
    <link rel="stylesheet" href="~/css/gameStyle.css" asp-append-version="true" />
</head>
<body>
@*     <iframe id="audio-frame"
            src="@Url.Action("AudioPlayer", "Audio")"
@*             style="style=" width:300px; 
                           height:200px; 
                           border:2px solid red;
                           pointer-events:none;
                           position:absolute;"> 
            style="width:0;height:0;border:0;opacity:0;pointer-events:none;position:absolute;">
    </iframe> *@
    <header class="galacticGradient">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 galacticGradient">
            <div class="container-fluid ">
                <a class="navbar-brand galacticTitleFontOnly" asp-area="" asp-controller="Home" asp-action="Index">Galactic Titans</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark gTZRG" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
@*                         <li>
                            <div class="nav-link text-dark gTZRG id="layout-loaded-time">
                                Layout loaded at: @DateTime.Now.ToLongTimeString()
                            </div>
                        </li> *@
                        @* 
                            TODO: rewrite getting claim, using proper microsoft documentation.
                            this hack works, but its a hack.
                        https://learn.microsoft.com/en-us/aspnet/core/security/authorization/claims?view=aspnetcore-9.0
                        *@
                        @{PlayerProfile userprofile = new PlayerProfile();}
                        @if (signInManager.IsSignedIn(User))
                        {
                            var empty = "";
                            var test = User.Claims;
                            List<string> parsedclaims = new List<string>();
                            foreach (var claim in test)
                            {
                                parsedclaims.Add(claim.ToString());
                                Console.WriteLine(claim);
                                if (claim.ToString().Contains("nameidentifier"))
                                {
                                    empty = claim.ToString().Substring(70, 36);
                                }
                            }
                            Guid userid = Guid.Parse(empty);
                            var user = await userManager.FindByIdAsync(userid.ToString());
                            userprofile = await PlayerProfilesServices.DetailsAsync(userid);
                            ViewData["thisPlayer"] = userprofile;
                            if  (user == null)
                            {
                                @:Could not find user.
                            }
                            else if (user.ProfileType == null)
                            {
                                @:Could not find users profile.
                            }
                            else if (user.ProfileType == true)
                                                {
                                <li class="nav-item">
                                    <a class="nav-link text-dark gTZRG" asp-area="" asp-controller="AdminAreas" asp-action="Index">Admin Panel</a>
                                </li>
                                <li>
                                    <a class="nav-link text-dark gTZRG" asp-area="" asp-controller="Emails" asp-action="Index">Test Email Sending</a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link text-dark gTZRG" asp-area="" asp-controller="Titans" asp-action="MyTitans" asp-route-id="@userprofile.ID">My Titans</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark gTZRG" asp-area="" asp-controller="Home" asp-action="PlanetsUnavailableError">Conquest the Galaxy</a>
                            </li>
                        }                        
                    </ul>
                    @* User login section on the navbar *@
                    <ul class="navbar-nav ml-auto">
                        @if (signInManager.IsSignedIn(User))
                        {
                            @if (userprofile == null)
                            {
                                
                            }
                            else
                            {
                                <li class="nav-item dropdown">
                                    <div class="dropdown">
                                        <button class="btn btn-info dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                                            Manage Account
                                        </button>
                                        <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                                            <li>
                                                <a class="dropdown-item" asp-controller="Accounts" asp-action="ResetPassword">Delete User</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" asp-controller="Accounts" asp-action="ChangePassword">Change Your Password</a>
                                            </li>
                                        </ul>
                                    </div>
                                </li>

                                <li class="nav-item">
                                    <form method="post" asp-controller="Accounts" asp-action="Logout">
                                        <button type="submit" class="nav-link btn btn-link py-0 gTZRG" style="width:auto; padding-top: 0.8rem;">
                                            Logout @userprofile.ScreenName @* @User.Identity.Name *@
                                        </button>
                                    </form>
                                </li>
                            }
                            
                        }
                        else
                        {
                            <li>
                                <a class="nav-link text-dark" asp-controller="Accounts" asp-action="Register">Register</a>
                            </li>
                            <li>
                                <a class="nav-link text-dark" asp-controller="Accounts" asp-action="Login">Login</a>
                            </li>
                        }
                        <li>
                            @* <button id="bgm-toggle">Play Music</button> *@
                            @* <button class="text-dark" id="start-music">Start Music</button> *@
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer bg-white galacticGradient gTZRG">
        @* 
                            TODO: rewrite getting claim, using proper microsoft documentation.
                            this hack works, but its a hack.
                        https://learn.microsoft.com/en-us/aspnet/core/security/authorization/claims?view=aspnetcore-9.0
                        *@
        @{
        }
        @if (signInManager.IsSignedIn(User))
        {
            var empty = "";
            var test = User.Claims;
            List<string> parsedclaims = new List<string>();
            foreach (var claim in test)
            {
                parsedclaims.Add(claim.ToString());
                Console.WriteLine(claim);
                if (claim.ToString().Contains("nameidentifier"))
                {
                    empty = claim.ToString().Substring(70, 36);
                }
            }
            Guid userid = Guid.Parse(empty);
            var user = await userManager.FindByIdAsync(userid.ToString());
            userprofile = await PlayerProfilesServices.DetailsAsync(userid);

            if (user == null)
            {
                @:Could not find user.
            }
            else if (user.ProfileType == null)
            {
                @:Could not find users profile.
            }
            else if (user.ProfileType == true)
            {
                <div class="container text-dark">
                    &copy; 2024 - Galactic Titans - <a class="text-dark gTZRG" asp-area="" asp-controller="Home" asp-action="ResourceListing">Developer Resources</a>
                </div>
            }
            else
            {
                <div class="container text-dark">
                    &copy; 2024 - Galactic Titans - <a class="text-dark gTZRG" asp-area="" asp-controller="Home" asp-action="Privacy">Terms of Usage</a>
                </div>
            }
        }
        else
        {
            <div class="container text-dark">
                &copy; 2024 - Galactic Titans - <a class="text-dark gTZRG" asp-area="" asp-controller="Home" asp-action="Privacy">Terms of Usage</a>
            </div>
            <div>
            </div>
            
        }
    </footer >
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
