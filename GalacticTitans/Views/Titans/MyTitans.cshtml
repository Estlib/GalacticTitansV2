@using GalacticTitans.Core.Domain
@model IEnumerable<GalacticTitans.Models.Titans.TitanOwnershipIndexViewModel>

@{
    int rowNumber = 1;
    int currentRow = 1;
    int currentTile = 1;
    int tilesInRow = 6;
    var thisprofile = ViewData["thisPlayer"] as PlayerProfile;
    //can get name with       ~.ScreenName
    //can get credits with    ~.GalacticCredits
    //can get scrapresource   ~.ScrapResource
    //can get victorycount    ~.Victories
    //can get players system  ~.MySolarSystem
}
