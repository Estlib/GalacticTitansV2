@* As a temporary function, currently, user gets to add and customize their titan *@




<div class="h1 gTZRG">@(thisprofile.ScreenName)'s Titans:</div>
<form method="post">
    <table class="">
        <thead>
            @if (!Model.Any())
            {
                <tr>
                    @* Later, once images have been implemented, add image here aswell *@
                    <th scope="col" colspan="4" class="gTZRG">
                        <span class="gXmc">Sorry, it appears that</span>
                        <span class="isPlayerName">@thisprofile.ScreenName</span>
                        <span class="gXmc">does not have any Titans yet.</span>
                    </th>
                </tr>
            }
            else
            {
            }


        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <table class="gTB">
                    <tr class="gTZRG"><td colspan="2">TitanName</td></tr>
                    <tr class="gTZRG"><td colspan="2"><img src="~/lib/gameasset/image/premadetitans/captainobvious.png" /></td></tr>
                    <tr class="gTZRG"><td>Type</td><td>Level</td></tr>
                    <tr class="gTZRG"><td colspan="2">XPBAROBJECT</td></tr>
                </table>
                rowNumber++;
            }
            else
            {
                @foreach (var titanownership in Model)
                {
                <td>
                    <table class="gTB">
                        <tr class="gTZRG"><td colspan="2">@titanownership.TitanName</td></tr>@* 
                        <tr class="gTZRG"><td colspan="2"><img width="256" src="@titan.Image.FirstOrDefault()" model="image" /></td></tr> *@
                        <tr class="gTZRG">
                            <td colspan="2">
                                @foreach (var image in titanownership.Image)
                                {
                                    <partial name="_ImageIndex" model="image" />
                                }
                            </td>
                        </tr>
                        <tr class="gTZRG"><td>@titanownership.TitanType</td><td>@titanownership.TitanLevel</td></tr>
                        <tr class="gTZRG"><td colspan="2">XPBAROBJECT</td></tr>
                    </table>
                </td>
                rowNumber++;
            }
        }

        </tbody>
    </table>
</form>
